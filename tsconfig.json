{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "obsidian": ["../action-tracker/node_modules/obsidian"]
    },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": ["ES2018", "DOM"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["**/*.ts"]
}
